rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Helper: get user role from Firestore
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // Helper: check if user has one of the allowed roles
    function hasRole(roles) {
      return isAuth() && getUserRole() in roles;
    }

    // Users collection
    // - Anyone authenticated can read
    // - User can create their own doc during signup
    // - User can update their own profile (name) but NOT role; CEO can update anything
    // - Only CEO can delete
    match /users/{userId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.auth.uid == userId;
      allow update: if isAuth() && (
        (request.auth.uid == userId && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']))
        || hasRole(['CEO'])
      );
      allow delete: if hasRole(['CEO']);
    }

    // Staff - CEO only
    match /staff/{docId} {
      allow read: if hasRole(['CEO']);
      allow write: if hasRole(['CEO']);
    }

    // Customers - all roles can read, CEO/Sales/Support can write
    match /customers/{docId} {
      allow read: if hasRole(['CEO', 'OPS_MANAGER', 'FINANCE', 'SALES', 'SUPPORT']);
      allow write: if hasRole(['CEO', 'SALES']);
    }

    // Shipments - CEO/Ops/Sales can read, CEO/Ops can write
    match /shipments/{docId} {
      allow read: if hasRole(['CEO', 'OPS_MANAGER', 'SALES']);
      allow write: if hasRole(['CEO', 'OPS_MANAGER']);
    }

    // Drivers & Trucks - CEO/Ops
    match /drivers/{docId} {
      allow read: if hasRole(['CEO', 'OPS_MANAGER']);
      allow write: if hasRole(['CEO', 'OPS_MANAGER']);
    }
    match /trucks/{docId} {
      allow read: if hasRole(['CEO', 'OPS_MANAGER']);
      allow write: if hasRole(['CEO', 'OPS_MANAGER']);
    }

    // Invoices - CEO/Finance
    match /invoices/{docId} {
      allow read: if hasRole(['CEO', 'FINANCE']);
      allow write: if hasRole(['CEO', 'FINANCE']);
    }

    // Expenses - CEO/Finance
    match /expenses/{docId} {
      allow read: if hasRole(['CEO', 'FINANCE']);
      allow write: if hasRole(['CEO', 'FINANCE']);
    }

    // Contact logs - all roles can read, all can write
    match /contactLogs/{docId} {
      allow read: if hasRole(['CEO', 'OPS_MANAGER', 'FINANCE', 'SALES', 'SUPPORT']);
      allow create: if isAuth();
      allow update, delete: if hasRole(['CEO']);
    }

    // Dashboard metrics - all roles including PENDING can read
    match /dashboardMetrics/{docId} {
      allow read: if isAuth();
      allow write: if false; // Only Cloud Functions can write
    }

    // Alerts - all roles including PENDING can read
    match /alerts/{docId} {
      allow read: if isAuth();
      allow write: if false; // Only Cloud Functions can write
    }

    // AI Insights - all roles including PENDING can read
    match /aiInsights/{docId} {
      allow read: if isAuth();
      allow write: if false; // Only Cloud Functions can write
    }
  }
}
